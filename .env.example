# MCP Server Config
NAME=mcp-template
VERSION=1.0.0
PORT=3000
MCP_TRANSPORT=stdio # sse or stdio
LOG_LEVEL=info

# Security
MCP_BEARER_TOKEN=your-static-token-here

# OAuth (For ChatGPT/OpenAI)
OAUTH_CLIENT_ID=mcp-client-id
OAUTH_CLIENT_SECRET=mcp-client-secret
OAUTH_REDIRECT_URI=https://chatgpt.com/oauth/callback/your-id

# AI Providers (Optional Modules)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

OPENAI_API_KEY=
