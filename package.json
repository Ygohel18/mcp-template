{
	"name": "@ygohel18/mcp-template",
	"version": "1.0.0",
	"description": "Comprehensive MCP Server Template with SSE, OAuth, AWS, OpenAI, and Skills support",
	"type": "module",
	"main": "dist/index.js",
	"author": "Yash Gohel (https://yashgohel.com)",
	"license": "MIT",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
		"lint": "eslint src --ext .ts",
		"typecheck": "tsc --noEmit",
		"prepare": "npm run build",
		"pm2:start": "pm2 start ecosystem.config.cjs",
		"pm2:stop": "pm2 stop ecosystem.config.cjs",
		"pm2:logs": "pm2 logs mcp-server",
		"docker:build": "docker build -t mcp-server .",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down"
	},
	"dependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.714.0",
		"@modelcontextprotocol/sdk": "^1.6.1",
		"axios": "^1.7.9",
		"cors": "^2.8.6",
		"dotenv": "^16.4.7",
		"ethers": "^6.13.5",
		"express": "^5.2.1",
		"openai": "^5.23.2",
		"winston": "^3.17.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.13.9",
		"jest": "^29.7.0",
		"ts-jest": "^29.2.6",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2"
	},
	"bin": {
		"mcp-template": "dist/index.js"
	},
	"overrides": {
		"glob": "^13.0.0"
	}
}
